# 1. 磁盘空间检测函数
function Check-DiskSpace {
    param(
        [int]$CMin,
        [int]$DMin
    )
    $cDrive = [System.IO.DriveInfo]::GetDrives() | Where-Object { $_.Name -eq 'C:\' -and $_.DriveType -eq [System.IO.DriveType]::Fixed }
    $dDrive = [System.IO.DriveInfo]::GetDrives() | Where-Object { $_.Name -eq 'D:\' -and $_.DriveType -eq [System.IO.DriveType]::Fixed }
    
    if (-not $cDrive) { throw "未检测到C盘" }
    if (-not $dDrive) { throw "未检测到D盘" }
    
    $cFreeGB = [math]::Round($cDrive.AvailableFreeSpace / 1GB, 1)
    $dFreeGB = [math]::Round($dDrive.AvailableFreeSpace / 1GB, 1)
    
    if ($cFreeGB -lt $CMin) { throw "C盘空间不足$CMin GB（当前：$cFreeGB GB）" }
    if ($dFreeGB -lt $DMin) { throw "D盘空间不足$DMin GB（当前：$dFreeGB GB）" }
    
    return @{ C = $cFreeGB; D = $dFreeGB }
}

# 2. 文件下载函数（增加文件完整性预校验）
function Download-File {
    param(
        [string]$Url,
        [string]$SavePath,
        [long]$SizeEst
    )
    Write-Host "`n==================================================" -ForegroundColor Yellow
    Write-Host "=============== 📥 开始下载AutoCAD $($cfg.Version) 安装包 ===============" -ForegroundColor Yellow
    Write-Host "==================================================" -ForegroundColor Yellow
    
    # 先删除旧的损坏压缩包（避免解压异常）
    if (Test-Path $SavePath -PathType Leaf) {
        Remove-Item $SavePath -Force
        Write-Host "🗑️ 已删除旧压缩包，重新下载`n" -ForegroundColor Cyan
    }

    $job = Start-Job -ScriptBlock {
        param($u, $p)
        [Net.ServicePointManager]::SecurityProtocol = [Net.SecurityProtocolType]::Tls12
        $wc = New-Object System.Net.WebClient
        $wc.Headers.Add("User-Agent", "Mozilla/5.0")
        try { $wc.DownloadFile($u, $p) }
        catch { Write-Error "下载失败：$_" }
        finally { $wc.Dispose() }
    } -ArgumentList $Url, $SavePath

    $startTime = Get-Date
    while ($job.State -eq "Running") {
        if (Test-Path $SavePath -PathType Leaf) {
            $currentSize = (Get-Item $SavePath).Length
            $elapsed = ((Get-Date) - $startTime).TotalSeconds
            $avgSpeed = if ($elapsed -gt 0) { [math]::Round(($currentSize / 1024) / $elapsed, 1) } else { 0 }
            $downloadedGB = [math]::Round($currentSize / 1GB, 2)
            $remainingSec = if ($avgSpeed -gt 0) { [math]::Round(($SizeEst - $currentSize)/1024/$avgSpeed,1) } else {0}
            $remainingMin = [math]::Max([math]::Round($remainingSec/60,1),0.1)
            Write-Host "`r📦 已下载：$downloadedGB GB | 速度：$avgSpeed KB/s | 剩余：$remainingMin 分钟" -NoNewline -ForegroundColor Yellow
        }
        Start-Sleep -Milliseconds 500
    }

    Receive-Job $job -Wait | Out-Null
    Remove-Job $job -Force

    # 下载后校验文件大小（避免空文件/损坏）
    if (-not (Test-Path $SavePath) -or (Get-Item $SavePath).Length -lt 100MB) {
        throw "下载的文件为空或损坏（文件大小异常）"
    }
    Write-Host "`n✅ 下载完成！文件大小：$([math]::Round((Get-Item $SavePath).Length / 1GB, 2)) GB`n" -ForegroundColor Green
}

# 3. 解压文件函数（修复压缩包识别，强制完整解压）
function Unzip-File {
    param(
        [string]$ZipPath,
        [string]$FinalDir
    )
    Write-Host "`n📦 正在解压中耐心等待..." -ForegroundColor Yellow
    try {
        # 先清空目标目录（避免旧文件干扰）
        if (Test-Path $FinalDir) {
            Remove-Item $FinalDir -Recurse -Force -ErrorAction SilentlyContinue
        }
        New-Item $FinalDir -ItemType Directory -Force | Out-Null

        Add-Type -AssemblyName System.IO.Compression.FileSystem
        $zipFile = [System.IO.Compression.ZipFile]::OpenRead($ZipPath)
        $entries = $zipFile.Entries
        $total = $entries.Count
        $current = 0

        foreach ($entry in $entries) {
            if (-not [string]::IsNullOrEmpty($entry.Name)) {
                # 直接解压到目标目录，保持压缩包内原始结构（和25版本一致）
                $targetPath = Join-Path -Path $FinalDir -ChildPath $entry.FullName
                
                # 创建目标目录（如果不存在）
                $targetDirectory = Split-Path -Path $targetPath -Parent
                if (-not (Test-Path -Path $targetDirectory)) {
                    [System.IO.Directory]::CreateDirectory($targetDirectory) | Out-Null
                }

                # 强制解压（覆盖，避免旧文件导致的结构异常）
                [System.IO.Compression.ZipFileExtensions]::ExtractToFile($entry, $targetPath, $true)
            }
            $current++
            $percent = [math]::Round(($current / $total) * 100, 1)
            Write-Host "`r解压进度：$percent% ($current/$total)" -NoNewline
        }
        
        # 释放压缩包句柄
        $zipFile.Dispose()

        Write-Host "`n✅ 解压完成！" -ForegroundColor Green
        
        # 自动删除C盘压缩包
        if (Test-Path $ZipPath -PathType Leaf) {
            Remove-Item $ZipPath -Force
            Write-Host "🗑️ 已自动删除压缩包" -ForegroundColor Green
        }

        # 解压后校验关键文件（确保和25版本结构一致）
        $checkFiles = @($SetupFilePath, $DataDirPath, $SourceAcadExe)
        foreach ($file in $checkFiles) {
            if (-not (Test-Path $file)) {
                Write-Host "⚠️ 解压后未找到关键文件：$file（可能压缩包结构异常）`n" -ForegroundColor Yellow
            }
        }
    }
    catch {
        Write-Host "`n❌ 解压失败：$($_.Exception.Message)" -ForegroundColor Red
        Read-Host "按任意键退出"
        exit 1
    }
}

# ===================== 核心安装流程 ======================
