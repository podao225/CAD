    # 解压文件（强制清空目标目录，完整解压）
    Unzip-File -ZipPath $ZipPath -FinalDir $cfg.InstallDir

    # 3. 安装前验证（严格匹配25版本结构）
    Write-Host "==================================================" -ForegroundColor Cyan
    Write-Host "=============== 🔍 安装前文件验证 ===============" -ForegroundColor Cyan
    Write-Host "==================================================`n" -ForegroundColor Cyan
    
    # 验证image目录
    if (-not (Test-Path $DataDirPath -PathType Container)) {
        throw "❌ 未找到image目录（$DataDirPath），压缩包结构不符合25版本规范"
    }
    $dataItems = Get-ChildItem -Path $DataDirPath -Recurse -ErrorAction SilentlyContinue
    if (-not $dataItems -or $dataItems.Count -eq 0) {
        throw "❌ image目录为空，压缩包可能损坏或下载不完整"
    }

    # 验证安装脚本
    if (-not (Test-Path $SetupFilePath -PathType Leaf)) {
        throw "❌ 未找到安装脚本：$SetupFilePath"
    }

    # 验证激活文件
    if ($cfg.ActivateExe -and -not (Test-Path $SourceAcadExe -PathType Leaf)) {
        throw "❌ 未找到激活文件：$SourceAcadExe"
    }
    
    Write-Host "✅ 所有文件验证通过（匹配25版本结构），开始安装`n" -ForegroundColor Green

    # 4. 启动安装程序
    Write-Host "🚀 启动AutoCAD $($cfg.Version) 安装程序...`n" -ForegroundColor Green
    Start-Process "cmd.exe" "/c start """" ""$SetupFilePath"" >> `"$logPath`" 2>&1" -Verb RunAs -Wait
    Write-Host "🎉 安装程序启动完成！`n" -ForegroundColor Green

    # 5. 检测安装结果
    $installOk = $false
    $waitCount = 0
    Write-Host "🔍 等待安装完成，检测主程序...`n" -ForegroundColor Cyan
    do {
        Start-Sleep -Seconds 5
        $waitCount++
        if (Test-Path $cfg.ExePath) { $installOk = $true }
    } while (-not $installOk -and $waitCount -lt 48) # 最多等待4分钟

    if (-not $installOk) {
        Write-Host "⚠️ 未检测到主程序（$($cfg.ExePath)）`n" -ForegroundColor Yellow
        $continue = Read-Host "是否强制继续后续操作？(Y/N)"
        if ($continue -notmatch "^[Yy]$") { exit 1 }
    }
    else {
        Write-Host "✅ 检测到AutoCAD $($cfg.Version) 主程序`n" -ForegroundColor Green
    }

    # 6. 激活（仅2023+版本需要）
    if ($cfg.ActivateExe) {
        Write-Host "==================================================" -ForegroundColor Cyan
        Write-Host "=============== 🔐 开始激活AutoCAD $($cfg.Version) ===============" -ForegroundColor Cyan
        Write-Host "==================================================`n" -ForegroundColor Cyan
        if (Test-Path $SourceAcadExe) {
            $exeDir = Split-Path $cfg.ExePath -Parent
            if (-not (Test-Path $exeDir)) { New-Item $exeDir -ItemType Directory -Force | Out-Null }
            
            # 备份原文件+替换激活文件
            if (Test-Path $cfg.ExePath) { Copy-Item $cfg.ExePath "$($cfg.ExePath).bak" -Force }
            Copy-Item $SourceAcadExe $cfg.ExePath -Force
            Write-Host "✅ 激活完成！`n" -ForegroundColor Green
            Remove-Item $SourceAcadExe -Force -ErrorAction SilentlyContinue
        }
        else {
            Write-Host "⚠️ 未找到激活文件（acad.exe），跳过激活`n" -ForegroundColor Yellow
        }
    }

    # 7. 最终完成提示（放大）
    Write-Host "==================================================" -ForegroundColor Green
    Write-Host "=============== 🎉 AutoCAD $($cfg.Version) 安装完成！ ===============" -ForegroundColor Green
    Write-Host "==================================================" -ForegroundColor Green
}
catch {
    Write-Host "`n==================================================" -ForegroundColor Red
    Write-Host "=============== ❌ 安装失败：$($_.Exception.Message) ❌ ===============" -ForegroundColor Red
    Write-Host "==================================================`n" -ForegroundColor Red
    Read-Host "按任意键退出"
    exit 1
}

