# ========== 功能函数：清理Windows Update重启项 ==========
function Clear-WURebootItem {
    param(
        [string]$BatFileName
    )
    Write-Host "`n🧹 正在清理Windows Update重启项..." -ForegroundColor Cyan
    $tempBatPath = Join-Path $env:TEMP $BatFileName
    @"
@echo off
:: 重启修复 - 清理Windows Update强制重启项
reg delete "HKEY_LOCAL_MACHINE\SOFTWARE\Microsoft\Windows\CurrentVersion\WindowsUpdate\Auto Update\RebootRequired" /f 2>nul
:: 运行完成
"@ | Out-File -FilePath $tempBatPath -Encoding ASCII
    Start-Process -FilePath "cmd.exe" -ArgumentList "/c ""$tempBatPath""" -Verb RunAs -Wait
    if (Test-Path $tempBatPath) {
        Remove-Item $tempBatPath -Force
    }
    Write-Host "✅ Windows Update重启项清理完成" -ForegroundColor Green
}

# ========== 功能函数：磁盘空间校验 ==========
function Check-DiskSpace {
    param(
        [int]$CMinSpaceGB,
        [bool]$ShowSpaceDetail
    )
    $cDrive = [System.IO.DriveInfo]::GetDrives() | Where-Object { $_.Name -eq 'C:\' -and $_.DriveType -eq [System.IO.DriveType]::Fixed }
    $dDrive = [System.IO.DriveInfo]::GetDrives() | Where-Object { $_.Name -eq 'D:\' -and $_.DriveType -eq [System.IO.DriveType]::Fixed }

    if (-not $cDrive) { throw "未检测到C盘" }
    if (-not $dDrive) { throw "未检测到D盘" }

    $cFreeGB = [math]::Round($cDrive.AvailableFreeSpace / 1GB, 1)
    $dFreeGB = [math]::Round($dDrive.AvailableFreeSpace / 1GB, 1)

    if ($ShowSpaceDetail) {
        if ($cFreeGB -lt $CMinSpaceGB) { throw "C盘空间不足$CMinSpaceGB GB（当前可用：$cFreeGB GB）" }
        if ($dFreeGB -lt 10) { throw "D盘空间不足10GB（当前可用：$dFreeGB GB）" }
    }
    else {
        if ($cFreeGB -lt $CMinSpaceGB) { throw "C盘空间不足$CMinSpaceGB GB（需存放压缩包）" }
        if ($dFreeGB -lt 10) { throw "D盘空间不足10GB（安装程序）" }
    }

    return @{ C = $cFreeGB; D = $dFreeGB }
}

# ========== 功能函数：下载安装包 ==========
function Download-InstallPackage {
    param(
        [string]$DownloadUrl,
        [string]$ZipPath,
        [double]$TotalSizeEstGB,
        [bool]$DownloadErrorCheck
    )
    Write-Host "`n📥 正在下载安装包（耐心等待）..." -ForegroundColor Yellow
    
    $jobScript = {
        param($url, $path, $checkError)
        [Net.ServicePointManager]::SecurityProtocol = [Net.ServicePointManager]::Tls12
        $webClient = New-Object System.Net.WebClient
        $webClient.Headers.Add("User-Agent", "Mozilla/5.0")
        try {
            $webClient.DownloadFile($url, $path)
        }
        catch {
            if ($checkError) {
                Write-Error "下载失败：$($_.Exception.Message)"
            }
        }
        finally {
            $webClient.Dispose()
        }
    }

    $job = Start-Job -ScriptBlock $jobScript -ArgumentList $DownloadUrl, $ZipPath, $DownloadErrorCheck

    $startTime = Get-Date
    $lastSize = 0
    $totalSizeEst = $TotalSizeEstGB * 1GB

    while ($job.State -eq "Running") {
        if (Test-Path $ZipPath -PathType Leaf) {
            $currentSize = (Get-Item $ZipPath).Length
            $currentTime = Get-Date
            $elapsed = ($currentTime - $startTime).TotalSeconds
            $avgSpeed = if ($elapsed -gt 0) { [math]::Round(($currentSize / 1024) / $elapsed, 1) } else { 0 }
            $downloadedGB = [math]::Round($currentSize / 1GB, 2)

            $remainingSize = $totalSizeEst - $currentSize
            $remainingSec = if ($avgSpeed -gt 0) { [math]::Round(($remainingSize / 1024) / $avgSpeed, 1) } else { 0 }
            $remainingMin = [math]::Round($remainingSec / 60, 1)
            $remainingMin = if ($remainingMin -lt 0.1) { 0.1 } else { $remainingMin }

            Write-Host "`r📦 已下载：$downloadedGB GB | 速度：$avgSpeed KB/s | 剩余时间：$remainingMin 分钟" -NoNewline -ForegroundColor Yellow
            $lastSize = $currentSize
        }
        Start-Sleep -Milliseconds 500
    }

    # 检查下载错误（仅2025/2026版本）
    if ($DownloadErrorCheck) {
        $jobResult = Receive-Job $job -Wait
        if ($jobResult -match "下载失败") {
            Remove-Job $job -Force
            throw $jobResult
        }
    }
    else {
        Receive-Job $job -Wait | Out-Null
    }
    Remove-Job $job -Force

    # 验证压缩包有效性（仅2025/2026版本）
    if ($DownloadErrorCheck) {
        if (-not (Test-Path $ZipPath) -or (Get-Item $ZipPath).Length -eq 0) {
            throw "下载的安装包为空或损坏"
        }
    }

    $endTime = Get-Date
    $totalTime = ($endTime - $startTime).TotalSeconds
    $finalSize = (Get-Item $ZipPath).Length
    $avgSpeed = [math]::Round($finalSize / 1024 / $totalTime, 1)
    $finalGB = [math]::Round($finalSize / 1GB, 2)
    Write-Host "`n✅ 下载完成！| 总大小：$finalGB GB | 平均速度：$avgSpeed KB/s" -ForegroundColor Green
}

# ========== 功能函数：解压安装包 ==========
function Extract-InstallPackage {
    param(
        [string]$ZipPath,
        [string]$FinalDir,
        [bool]$IsNewVersion # 是否是2023+版本（需要截断顶层文件夹）
    )
    Write-Host "`n📦 正在解压中耐心等待..." -ForegroundColor Yellow
    try {
        Add-Type -AssemblyName System.IO.Compression.FileSystem
        $zipFile = [System.IO.Compression.ZipFile]::OpenRead($ZipPath)
        $entries = $zipFile.Entries
        $total = $entries.Count
        $current = 0

        # 确保解压目录存在
        if (-not (Test-Path $FinalDir)) {
            New-Item -Path $FinalDir -ItemType Directory -Force | Out-Null
        }

        # 2023+版本：截断顶层文件夹；2020/2021版本：分割路径
        $topFolder = ""
        if ($IsNewVersion) {
            $topFolder = $entries | Where-Object { $_.FullName -match '^[^/]+/$' } | Select-Object -First 1 -ExpandProperty FullName
            if (-not $topFolder) { $topFolder = "" }
        }

        foreach ($entry in $entries) {
            if (-not [string]::IsNullOrEmpty($entry.Name)) {
                if ($IsNewVersion) {
                    # 2023+版本：截断顶层文件夹
                    $relativePath = if ($entry.FullName.StartsWith($topFolder)) {
                        $entry.FullName.Substring($topFolder.Length)
                    } else {
                        $entry.FullName
                    }
                    $targetPath = Join-Path $FinalDir $relativePath
                }
                else {
                    # 2020/2021版本：分割路径
                    $entryParts = $entry.FullName -split '[\\/]'
                    if ($entryParts.Count -gt 1) {
                        $innerPath = $entryParts[1..($entryParts.Count-1)] -join '\'
                        $targetPath = Join-Path $FinalDir $innerPath
                    } else {
                        $targetPath = Join-Path $FinalDir $entry.FullName
                    }
                }
                
                $targetDir = Split-Path $targetPath -Parent
                if (-not (Test-Path $targetDir)) {
                    [System.IO.Directory]::CreateDirectory($targetDir) | Out-Null
                }

                # 仅解压文件（跳过目录条目）
                if (-not $entry.FullName.EndsWith("/")) {
                    [System.IO.Compression.ZipFileExtensions]::ExtractToFile($entry, $targetPath, $true)
                }
            }
            $current++
            $percent = [math]::Round(($current / $total) * 100, 1)
            Write-Host "`r解压进度：$percent% ($current/$total)" -NoNewline
        }
        $zipFile.Dispose()
        Write-Host "`n✅ 解压完成！" -ForegroundColor Green
        
        # 删除压缩包
        if (Test-Path $ZipPath -PathType Leaf) {
            Remove-Item $ZipPath -Force
            Write-Host "🗑️ 已自动打扫压缩包" -ForegroundColor Green
        }
    }
    catch {
        throw "解压失败：$($_.Exception.Message)"
    }
}

# ========== 功能函数：安装+激活（适配不同版本） ==========
function Install-CAD {
    param(
        [hashtable]$VersionConfig
    )
    $version = $VersionConfig.Keys | Where-Object { $CADVersionsConfig[$_] -eq $VersionConfig }
    Write-Host "`n========================================" -ForegroundColor Cyan
    Write-Host "          开始安装 AutoCAD $version          " -ForegroundColor Cyan
    Write-Host "========================================" -ForegroundColor Cyan

    # 1. 清理WU重启项
    Clear-WURebootItem -BatFileName $VersionConfig.CleanWuBatName

    # 2. 定义核心路径
    $ImageDir = Join-Path $VersionConfig.FinalDir $VersionConfig.ImageDirName
    $logPath = Join-Path $VersionConfig.FinalDir "install_log.txt"

    # 3. 检测是否已有完整安装文件
    Write-Host "`n🔍 磁盘检测中（AutoCAD $version）..." -ForegroundColor Cyan
    $installFileExists = Test-Path $VersionConfig.InstallFilePath -PathType Leaf
    $imageDirExists = Test-Path $ImageDir -PathType Container
    $skipAll = $false

    if ($installFileExists -and $imageDirExists) {
        $imageItems = Get-ChildItem -Path $ImageDir -Recurse -ErrorAction SilentlyContinue
        if ($imageItems -and $imageItems.Count -gt 0) {
            Write-Host "✅ 检测到AutoCAD $version完整安装文件，跳过下载+解压" -ForegroundColor Green
            $skipAll = $true
        }
    }

    if (-not $skipAll) {
        # 4. 磁盘空间校验
        try {
            $diskInfo = Check-DiskSpace -CMinSpaceGB $VersionConfig.CMinSpaceGB -ShowSpaceDetail $VersionConfig.ShowSpaceDetail
            Write-Host "`n🔍 磁盘剩余空间：C盘 $($diskInfo.C) GB | D盘 $($diskInfo.D) GB" -ForegroundColor Cyan
        }
        catch {
            Write-Host "❌ $($_.Exception.Message)" -ForegroundColor Red
            Read-Host "按任意键退出程序"
            exit 0
        }

        # 5. 下载安装包
        Write-Host "`n❌ 未检测到AutoCAD $version完整文件，开始下载" -ForegroundColor Cyan
        if (-not (Test-Path $VersionConfig.ZipPath -PathType Leaf)) {
            try {
                Download-InstallPackage -DownloadUrl $VersionConfig.DownloadUrl `
                    -ZipPath $VersionConfig.ZipPath `
                    -TotalSizeEstGB $VersionConfig.TotalSizeEstGB `
                    -DownloadErrorCheck $VersionConfig.DownloadErrorCheck
            }
            catch {
                Write-Host "❌ $($_.Exception.Message)" -ForegroundColor Red
                Read-Host "按任意键退出程序"
                exit 0
            }
        }
        else {
            Write-Host "✅ C盘已存在AutoCAD $version压缩包，跳过下载" -ForegroundColor Green
        }

        # 6. 解压安装包
        try {
            Extract-InstallPackage -ZipPath $VersionConfig.ZipPath `
                -FinalDir $VersionConfig.FinalDir `
                -IsNewVersion ($version -ge 2023)
        }
        catch {
            Write-Host "❌ $($_.Exception.Message)" -ForegroundColor Red
            Read-Host "按任意键退出程序"
            exit 0
        }
    }

    # 7. 安装前验证
    Write-Host "`n🔍 AutoCAD $version安装前二次验证..." -ForegroundColor Cyan
    if (-not (Test-Path $ImageDir -PathType Container)) {
        Write-Host "❌ $($VersionConfig.ImageDirName)文件夹不存在" -ForegroundColor Red
        Read-Host "按任意键退出程序"
        exit 0
    }
    $imageItems = Get-ChildItem -Path $ImageDir -Recurse -ErrorAction SilentlyContinue
    if ($imageItems -eq $null -or $imageItems.Count -eq 0) {
        Write-Host "❌ $($VersionConfig.ImageDirName)文件夹为空" -ForegroundColor Red
        Read-Host "按任意键退出程序"
        exit 0
    }
    if (-not (Test-Path $VersionConfig.InstallFilePath)) {
        $installFileName = if ($VersionConfig.IsBatInstall) { $VersionConfig.BatFileName } else { "666.lnk" }
        Write-Host "❌ 未找到安装文件 $installFileName" -ForegroundColor Red
        Read-Host "按任意键退出程序"
        exit 0
    }
    Write-Host "✅ AutoCAD $version所有验证通过，开始安装" -ForegroundColor Green

    # 8. 执行安装
    try {
        if ($VersionConfig.IsBatInstall) {
            Write-Host "🔄 正在启动 AutoCAD $version 安装，请耐心等待安装完成..." -ForegroundColor Cyan
            $installProcess = Start-Process -FilePath "cmd.exe" -ArgumentList "/c start """" ""$($VersionConfig.InstallFilePath)"" >> `"$logPath`" 2>&1" -Verb RunAs -PassThru

            # 等待Installer.exe进程结束（2023+版本）
            $installerWaitCount = 0
            $maxInstallerWait = 360  # 30分钟超时
            do {
                Start-Sleep -Seconds 5
                $installerProcess = Get-Process -Name "Installer" -ErrorAction SilentlyContinue
                $installerWaitCount++
                
                if ($installerWaitCount -ge $maxInstallerWait) {
                    Write-Host "`n⚠️ Installer进程等待超时，强制继续检测" -ForegroundColor Yellow
                    break
                }
            } while ($installerProcess -ne $null)

            # 检测acad.exe是否存在（2023+版本）
            Write-Host "🔍 安装检测中..." -ForegroundColor Cyan
            $cadInstalled = $false
            $fileWaitCount = 0
            $maxFileWait = 240  # 20分钟超时

            do {
                Start-Sleep -Seconds 5
                $fileWaitCount++
                
                if (Test-Path $VersionConfig.TargetAcadExe -PathType Leaf) {
                    $cadInstalled = $true
                }

                if ($fileWaitCount -ge $maxFileWait) {
                    Write-Host "`n❌ 检测超时：$($VersionConfig.TargetAcadExe) 文件未找到" -ForegroundColor Red
                    $userChoice = Read-Host "是否强制继续激活流程？(Y/N)"
                    if ($userChoice -eq "Y" -or $userChoice -eq "y") {
                        $cadInstalled = $true
                    } else {
                        Read-Host "按任意键退出程序"
                        exit 0
                    }
                }
            } while (-not $cadInstalled)

            Write-Host "✅ 安装检测完成" -ForegroundColor Green
            Start-Sleep -Seconds 3
        }
        else {
            # 2020/2021版本：直接运行lnk（原版逻辑，未改动）
            Start-Process -FilePath "cmd.exe" -ArgumentList "/c start """" ""$($VersionConfig.InstallFilePath)"" >> `"$logPath`" 2>&1" -Verb RunAs -Wait
        }

        Write-Host "`n🎉 AutoCAD $version 安装完成！" -ForegroundColor Green
        Write-Host "ℹ️ 日志已保存到：$logPath" -ForegroundColor Cyan

        # 删除安装文件
        if (Test-Path $VersionConfig.InstallFilePath -PathType Leaf) {
            Remove-Item $VersionConfig.InstallFilePath -Force
            $installFileType = if ($VersionConfig.IsBatInstall) { "批处理文件" } else { "快捷方式" }
            Write-Host "🗑️ 已自动打扫安装$installFileType" -ForegroundColor Green
        }

        # 激活流程（2023+版本）
        if ($VersionConfig.HasActivation) {
            Write-Host "`n📤 开始激活中..." -ForegroundColor Cyan
            if (Test-Path $VersionConfig.SourceAcadExe -PathType Leaf) {
                # 确保目标目录存在
                if (-not (Test-Path $VersionConfig.TargetAcadDir -PathType Container)) {
                    New-Item -Path $VersionConfig.TargetAcadDir -ItemType Directory -Force | Out-Null
                    Write-Host "📁 已创建目标目录：$($VersionConfig.TargetAcadDir)" -ForegroundColor Yellow
                }
                
                # 备份原文件
                if (Test-Path $VersionConfig.TargetAcadExe -PathType Leaf) {
                    Copy-Item -Path $VersionConfig.TargetAcadExe -Destination "$($VersionConfig.TargetAcadExe).bak" -Force -ErrorAction SilentlyContinue
                }
                # 替换激活文件
                Copy-Item -Path $VersionConfig.SourceAcadExe -Destination $VersionConfig.TargetAcadExe -Force
                Write-Host "✅ 已激活完成" -ForegroundColor Green

                Remove-Item -Path $VersionConfig.SourceAcadExe -Force
                Write-Host "🗑️ 已打扫源文件" -ForegroundColor Green
            }
            else {
                Write-Host "⚠️ 未找到源文件：$($VersionConfig.SourceAcadExe)，跳过复制替换" -ForegroundColor Yellow
            }
        }
    }
    catch {
        Write-Host "`n❌ AutoCAD $version 安装/激活失败：$($_.Exception.Message)" -ForegroundColor Red
        Read-Host "按任意键退出程序"
        exit 0
    }

    Read-Host "`nAutoCAD $version 安装流程结束，按任意键退出程序"
    exit 0
}

# ========== 界面函数：版本选择菜单 ==========
function Show-VersionMenu {
    Clear-Host
    Write-Host "========================================" -ForegroundColor Cyan
    Write-Host "          AutoCAD 多版本安装程序           " -ForegroundColor Cyan
    Write-Host "========================================" -ForegroundColor Cyan
    Write-Host "请选择要安装的AutoCAD版本：" -ForegroundColor White
    $index = 1
    $versionList = @()
    foreach ($version in $CADVersionsConfig.Keys | Sort-Object) {
        Write-Host "$index) AutoCAD $version" -ForegroundColor White
        $versionList += $version
        $index++
    }
    Write-Host "0) 退出程序" -ForegroundColor White
    Write-Host "========================================" -ForegroundColor Cyan
    return $versionList
}

# ========== 主程序入口 ==========
function Main {
    # 显示版本菜单（仅显示一次，移除循环）
    $versionList = Show-VersionMenu
    $choice = Read-Host "请输入选项编号"

    # 验证输入
    if (-not [int]::TryParse($choice, [ref]$null)) {
        Write-Host "❌ 输入无效，请输入数字！" -ForegroundColor Red
        Read-Host "按任意键退出程序"
        exit 0
    }

    $choiceInt = [int]$choice
    if ($choiceInt -eq 0) {
        Write-Host "`n👋 退出程序，感谢使用！" -ForegroundColor Cyan
        exit 0
    }
    elseif ($choiceInt -ge 1 -and $choiceInt -le $versionList.Count) {
        $selectedVersion = $versionList[$choiceInt - 1]
        Install-CAD -VersionConfig $CADVersionsConfig[$selectedVersion]
    }
    else {
        Write-Host "❌ 选项不存在，请重新选择！" -ForegroundColor Red
        Read-Host "按任意键退出程序"
        exit 0
    }
}

# 启动主程序
Main
